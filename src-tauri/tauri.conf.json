{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stacks",
  "version": "0.0.2",
  "identifier": "co.dnk.stacks",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Stacks",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 14 },
        "backgroundColor": "#09090b"
      },
      {
        "label": "splash",
        "url": "splash/index.html",
        "width": 420,
        "height": 420,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dogfootruler-kr/ims-desktop-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFNTNCM0NERDJDNkNGOTMKUldTVHo4YlN6Yk5UL2w2cmhjK1RMVU9DbHNDcEl2RGhoWnFobWY3MmVKbmtqbFJicG9jVyt4bE4K"
    }
  }
}
